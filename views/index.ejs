<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shreeyash College Admissions Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#241f1a;
    --paper:#f6f1e6;
    --paper-2:#efe7d6;
    --navy:#1c2c4a;
    --navy-2:#2c3f66;
    --gold:#c4972a;
    --maroon:#7e2438;
    --line:#cfc3a4;
  }

  *{ box-sizing:border-box; }

  body{
    margin:0;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:32px 16px;
    font-family:'Inter', Arial, sans-serif;
    color:var(--ink);
    background:
      radial-gradient(circle at 1px 1px, rgba(28,44,74,0.08) 1px, transparent 0) 0 0/22px 22px,
      var(--paper);
  }

  .ticket{
    position:relative;
    width:420px;
    max-width:100%;
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:4px;
    box-shadow: 0 18px 40px rgba(28,44,74,0.18), 0 2px 0 rgba(0,0,0,0.03);
    overflow:hidden;
    animation: rise 0.7s cubic-bezier(.2,.8,.2,1) both;
  }

  .ticket::before, .ticket::after{
    content:"";
    position:absolute;
    width:22px; height:22px;
    background:radial-gradient(circle, transparent 60%, var(--paper) 61%), #ACB6E5;
    background: var(--paper);
    border-radius:50%;
    box-shadow: 0 0 0 1px var(--line) inset;
  }

  .band{
    background:var(--navy);
    background-image: linear-gradient(160deg, var(--navy) 0%, var(--navy-2) 100%);
    color:#f1ead8;
    padding:34px 36px 28px;
    text-align:center;
    position:relative;
  }

  .seal{
    width:64px; height:64px;
    margin:0 auto 14px;
    border-radius:50%;
    background: radial-gradient(circle at 35% 30%, #e3bd5a, var(--gold) 60%, #9c7414 100%);
    display:flex; align-items:center; justify-content:center;
    box-shadow: 0 0 0 3px rgba(241,234,216,0.18), 0 4px 10px rgba(0,0,0,0.35);
    animation: settle 0.9s 0.15s cubic-bezier(.2,.8,.2,1) both;
  }
  .seal span{
    font-family:'Spectral', serif;
    font-weight:700;
    font-size:22px;
    color:var(--navy);
    letter-spacing:0.5px;
  }

  .eyebrow{
    font-size:11px;
    letter-spacing:2.5px;
    text-transform:uppercase;
    color:#cdb978;
    margin:0 0 8px;
  }

  h1{
    font-family:'Spectral', serif;
    font-weight:600;
    font-size:26px;
    line-height:1.25;
    margin:0 0 8px;
  }

  .tagline{
    font-size:13px;
    color:#cfd5e4;
    margin:0;
    line-height:1.5;
  }

  .perforation{
    height:0;
    border-top:2px dashed var(--line);
    position:relative;
  }

  .body{
    padding:30px 34px 32px;
  }

  .option{
    display:flex;
    align-items:center;
    gap:14px;
    text-decoration:none;
    color:var(--ink);
    padding:16px 14px;
    border-radius:6px;
    border:1px solid transparent;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .option + .option{ margin-top:6px; }

  .option:hover, .option:focus-visible{
    background:var(--paper-2);
    border-color:var(--line);
    transform: translateX(4px);
  }

  .option:focus-visible{
    outline:2px solid var(--maroon);
    outline-offset:2px;
  }

  .icon{
    flex:0 0 auto;
    width:38px; height:38px;
    border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    background:var(--navy);
    color:#f1ead8;
  }

  .icon svg{ width:18px; height:18px; }

  .option.signup .icon{ background:var(--maroon); }

  .option-text{ flex:1; }

  .option-text .label{
    font-family:'Spectral', serif;
    font-weight:600;
    font-size:16px;
    display:block;
  }

  .option-text .desc{
    font-size:12.5px;
    color:#6b6357;
    margin-top:2px;
  }

  .arrow{
    color:#9a8f78;
    font-size:18px;
    transition: transform 0.25s ease;
  }
  .option:hover .arrow{ transform: translateX(3px); color:var(--ink); }

  .divider-row{
    display:flex;
    align-items:center;
    gap:10px;
    margin:18px 0;
    color:#9a8f78;
    font-size:11px;
    letter-spacing:1.5px;
    text-transform:uppercase;
  }
  .divider-row::before, .divider-row::after{
    content:"";
    flex:1;
    height:1px;
    background:var(--line);
  }

  .footer-note{
    text-align:center;
    font-size:11.5px;
    color:#8a8270;
    margin-top:4px;
  }

  @keyframes rise{
    from{ opacity:0; transform:translateY(18px); }
    to{ opacity:1; transform:translateY(0); }
  }
  @keyframes settle{
    from{ opacity:0; transform:scale(0.6) rotate(-8deg); }
    to{ opacity:1; transform:scale(1) rotate(0deg); }
  }

  @media (prefers-reduced-motion: reduce){
    .ticket, .seal{ animation:none; }
    .option, .arrow{ transition:none; }
  }

  @media (max-width:420px){
    .band{ padding:28px 22px 24px; }
    .body{ padding:24px 18px 26px; }
  }
</style>
</head>
<body>

  <div class="ticket">
    <div class="band">
      <div class="seal" aria-hidden="true"><span>SC</span></div>
      <p class="eyebrow">Admissions Portal · 2026&ndash;27</p>
      <h1>Shreeyash College</h1>
      <p class="tagline">Your enrollment record starts here. Choose how you'd like to continue.</p>
    </div>

    <div class="perforation" aria-hidden="true"></div>

    <div class="body">
      <a href="/signup" class="option signup">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M19 8v6M22 11h-6"></path></svg>
        </span>
        <span class="option-text">
          <span class="label">New Student</span>
          <span class="desc">Start a fresh application</span>
        </span>
        <span class="arrow">&rarr;</span>
      </a>

      <div class="divider-row">or</div>

      <a href="/login" class="option login">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><path d="M10 17l5-5-5-5"></path><path d="M15 12H3"></path></svg>
        </span>
        <span class="option-text">
          <span class="label">Returning Student</span>
          <span class="desc">Continue to your account</span>
        </span>
        <span class="arrow">&rarr;</span>
      </a>

      <p class="footer-note">Need help? Contact the admissions office.</p>
    </div>
  </div>

</body>
</html>
