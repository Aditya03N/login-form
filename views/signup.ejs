<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shreeyash College — New Student Registration</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#241f1a;
    --paper:#f6f1e6;
    --paper-2:#efe7d6;
    --navy:#1c2c4a;
    --navy-2:#2c3f66;
    --gold:#c4972a;
    --maroon:#7e2438;
    --maroon-2:#982c45;
    --line:#cfc3a4;
  }

  *{ box-sizing:border-box; }

  body{
    margin:0;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:32px 16px;
    font-family:'Inter', Arial, sans-serif;
    color:var(--ink);
    background:
      radial-gradient(circle at 1px 1px, rgba(28,44,74,0.08) 1px, transparent 0) 0 0/22px 22px,
      var(--paper);
  }

  .ticket{
    width:380px;
    max-width:100%;
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:4px;
    box-shadow: 0 18px 40px rgba(28,44,74,0.18), 0 2px 0 rgba(0,0,0,0.03);
    overflow:hidden;
    animation: rise 0.6s cubic-bezier(.2,.8,.2,1) both;
  }

  .band{
    background:var(--navy);
    background-image: linear-gradient(160deg, var(--navy) 0%, var(--navy-2) 100%);
    color:#f1ead8;
    padding:30px 32px 24px;
    text-align:center;
  }

  .seal{
    width:52px; height:52px;
    margin:0 auto 12px;
    border-radius:50%;
    background: radial-gradient(circle at 35% 30%, #e3bd5a, var(--gold) 60%, #9c7414 100%);
    display:flex; align-items:center; justify-content:center;
    box-shadow: 0 0 0 3px rgba(241,234,216,0.18), 0 4px 10px rgba(0,0,0,0.35);
  }
  .seal span{
    font-family:'Spectral', serif;
    font-weight:700;
    font-size:18px;
    color:var(--navy);
  }

  .eyebrow{
    font-size:10.5px;
    letter-spacing:2.5px;
    text-transform:uppercase;
    color:#cdb978;
    margin:0 0 6px;
  }

  h1{
    font-family:'Spectral', serif;
    font-weight:600;
    font-size:21px;
    line-height:1.3;
    margin:0 0 6px;
  }

  .tagline{
    font-size:12.5px;
    color:#cfd5e4;
    margin:0;
    line-height:1.5;
  }

  .perforation{
    height:0;
    border-top:2px dashed var(--line);
  }

  .body{
    padding:28px 32px 30px;
  }

  label{
    display:block;
    font-size:11.5px;
    font-weight:600;
    letter-spacing:0.5px;
    text-transform:uppercase;
    color:#5c5444;
    margin-bottom:6px;
  }

  input{
    width:100%;
    padding:11px 12px;
    margin-bottom:18px;
    border:1px solid var(--line);
    border-radius:5px;
    background:#fff;
    font-family:'Inter', Arial, sans-serif;
    font-size:14px;
    color:var(--ink);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  input:focus{
    outline:none;
    border-color:var(--maroon);
    box-shadow: 0 0 0 3px rgba(126,36,56,0.14);
  }

  button{
    width:100%;
    background:var(--maroon);
    background-image: linear-gradient(160deg, var(--maroon-2), var(--maroon));
    color:#fff;
    padding:13px 20px;
    border:none;
    border-radius:5px;
    font-family:'Inter', Arial, sans-serif;
    font-size:14.5px;
    font-weight:600;
    letter-spacing:0.3px;
    cursor:pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  button:hover{ transform: translateY(-1px); box-shadow:0 6px 14px rgba(126,36,56,0.3); }
  button:focus-visible{ outline:2px solid var(--navy); outline-offset:2px; }

  .switch{
    text-align:center;
    font-size:12.5px;
    color:#6b6357;
    margin-top:18px;
  }
  .switch a{
    color:var(--maroon);
    font-weight:600;
    text-decoration:none;
  }
  .switch a:hover{ text-decoration:underline; }

  @keyframes rise{
    from{ opacity:0; transform:translateY(16px); }
    to{ opacity:1; transform:translateY(0); }
  }
  @media (prefers-reduced-motion: reduce){
    .ticket{ animation:none; }
    button{ transition:none; }
  }
</style>
</head>
<body>

  <div class="ticket">
    <div class="band">
      <div class="seal" aria-hidden="true"><span>SC</span></div>
      <p class="eyebrow">Admissions Portal · 2026&ndash;27</p>
      <h1>New Student Registration</h1>
      <p class="tagline">Create your account to begin the application.</p>
    </div>

    <div class="perforation" aria-hidden="true"></div>

    <div class="body">
      <form action="/signup" method="POST">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autocomplete="username">

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password">

        <button type="submit">Create Account</button>
      </form>

      <p class="switch">Already registered? <a href="/login">Sign in</a></p>
    </div>
  </div>

</body>
</html>